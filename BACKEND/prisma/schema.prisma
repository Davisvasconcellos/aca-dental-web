generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Paciente {
  id                    String    @id @default(uuid())
  id_sDental            String
  nome                  String
  telefone              String?
  organization_id       String
  
  ultima_limpeza_data   DateTime?
  ultima_evolucao_data  DateTime?
  ultimo_proc           String?
  total_evolucoes       Int       @default(0)
  score                 Int       @default(0)
  
  orcamentos            Orcamento[]
  campanhas_alvo        CampanhaAlvo[]
  
  organization          Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  
  @@unique([id_sDental, organization_id])
}

model Orcamento {
  id                    String    @id
  paciente_id           String
  organization_id       String
  descricao             String?
  status                String
  data_orcamento        DateTime
  valor_total           Float
  
  paciente              Paciente  @relation(fields: [paciente_id], references: [id])
  organization          Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  tratamentos           Tratamento[]
}

model Tratamento {
  id            Int        @id @default(autoincrement())
  orcamento_id  String
  nome          String
  valor         Float
  
  orcamento     Orcamento  @relation(fields: [orcamento_id], references: [id], onDelete: Cascade)
}

model Campanha {
  id                String         @id @default(uuid())
  nome              String
  mensagem_template String
  botoes            String?
  status            String
  organization_id   String
  data_inicio       DateTime       @default(now())
  data_fim          DateTime?
  
  alvos             CampanhaAlvo[]
  organization      Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
}

model CampanhaAlvo {
  campanha_id        String
  paciente_id        String
  status_envio       String
  data_envio         DateTime?
  resposta_texto     String?
  data_resposta      DateTime?
  typebot_session_id String?
  
  campanha      Campanha   @relation(fields: [campanha_id], references: [id], onDelete: Cascade)
  paciente      Paciente   @relation(fields: [paciente_id], references: [id], onDelete: Cascade)
  
  @@id([campanha_id, paciente_id])
}

model Configuracao {
  id              Int           @id @default(autoincrement())
  chave           String
  valor           String
  organization_id String
  
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([chave, organization_id])
}

model MensagemTemplate {
  id              String       @id @default(uuid())
  titulo          String
  texto           String
  botoes          String?      // Armazena JSON com os botões configurados
  organization_id String
  
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
}

model Organization {
  id           String    @id @default(uuid())
  nome         String
  logo         String?
  evo_instance String?
  
  usuarios     Usuario[]
  pacientes    Paciente[]
  orcamentos   Orcamento[]
  campanhas    Campanha[]
  configuracoes Configuracao[]
  mensagens    MensagemTemplate[]
}

model Usuario {
  id              String        @id @default(uuid())
  email           String        @unique
  senha           String
  role            String        @default("ADMIN")
  organization_id String?
  
  organization    Organization? @relation(fields: [organization_id], references: [id], onDelete: Cascade)
}
